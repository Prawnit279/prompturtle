# Supabase — copy this file to .env and replace placeholders with your values.
# Dashboard → <your-project-ref> → Settings → Database → Connection string

# Pooled connection (runtime / Prisma Client)
DATABASE_URL="postgresql://postgres.<your-project-ref>:REPLACE_ME@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (Prisma migrations only)
DIRECT_URL="postgresql://postgres.<your-project-ref>:REPLACE_ME@db.<your-project-ref>.supabase.co:5432/postgres"

# Clerk Auth (Dashboard → API Keys)
CLERK_SECRET_KEY=sk_live_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# App
PORT=3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development

# Stripe (TEST keys only — never use sk_live_ here)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe price IDs — copy from output of scripts/seed-stripe-prices.ts
STRIPE_PRICE_STARTER=price_REPLACE_ME
STRIPE_PRICE_GROWTH=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE=price_REPLACE_ME

# RLS integration tests (non-superuser role — see migration 0003)
# APP_DB_URL=postgresql://app_user:<password>@db.<your-project-ref>.supabase.co:5432/postgres
# RLS_E2E=1
