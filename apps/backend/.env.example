# Supabase — copy this file to .env and replace REPLACE_ME with your DB password.
# Dashboard → aowvybglokzbcuerlago → Settings → Database → Connection string

# Pooled connection (runtime / Prisma Client)
DATABASE_URL="postgresql://postgres.aowvybglokzbcuerlago:REPLACE_ME@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (Prisma migrations only)
DIRECT_URL="postgresql://postgres.aowvybglokzbcuerlago:REPLACE_ME@db.aowvybglokzbcuerlago.supabase.co:5432/postgres"

# Clerk Auth (Dashboard → API Keys)
CLERK_SECRET_KEY=sk_live_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# App
PORT=3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development

