generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector", schema: "extensions")]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TenantTier {
  STARTER
  GROWTH
  ENTERPRISE
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  TOOL_CALL
  AUTH_EVENT
  GUARDRAIL_VIOLATION
  APPROVAL_REQUESTED
  APPROVAL_DECIDED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  EXPIRED
}

enum ApprovalTrigger {
  HIGH_SHIPMENT_COST
  LOW_HTS_CONFIDENCE
  CARRIER_CHANGE_ON_PO
}

/// Phase 2 stubs DO NOT REMOVE
enum Phase2Feature {
  CARBON_TRACKING
  SUPPLIER_RISK
}

enum BolType {
  TRUCK_BOL
  AIR_WAYBILL
  OCEAN_BOL
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Tenant {
  id                 String      @id  // Clerk org_id (e.g. "org_xxx") — not a UUID
  name               String
  tier               TenantTier  @default(STARTER)
  api_key_hash       String?
  // Contact — PR 6.1
  email                  String?
  // Stripe billing — PR 5.2
  stripe_customer_id     String?
  stripe_subscription_id String?
  stripe_price_id        String?
  subscription_status    String?  @default("inactive")
  created_at             DateTime @default(now())
  updated_at         DateTime    @updatedAt

  // Relations
  api_keys          ApiKey[]
  tool_calls        ToolCall[]
  audit_events      AuditEvent[]
  guardrail_rules   GuardrailRule[]
  billing_usage     BillingUsage[]
  embeddings        EmbeddingStore[]
  users             User[]
  approval_requests ApprovalRequest[]
  webhooks          Webhook[]
  guardrail_config  GuardrailConfig?

  @@map("tenants")
}

model ApiKey {
  id           String    @id @default(uuid()) @db.Uuid
  tenant_id    String
  tenant       Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  /// First 12 chars of raw key — safe to display in dashboard
  prefix       String
  /// SHA-256 of raw key — used for authentication; raw key never stored
  key_hash     String    @unique
  name         String
  revoked_at   DateTime?
  last_used_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([tenant_id])
  @@index([key_hash])
  @@map("api_keys")
}

model ToolCall {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_id   String
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  mcp_server  String
  tool_name   String
  model_used  String
  input_tokens  Int
  output_tokens Int
  cost_usd      Decimal  @db.Decimal(12, 6)
  latency_ms    Int
  success       Boolean  @default(true)
  bol_type      BolType?
  created_at    DateTime @default(now())

  @@index([tenant_id, created_at])
  @@map("tool_calls")
}

model AuditEvent {
  id          String      @id @default(uuid()) @db.Uuid
  tenant_id   String
  tenant      Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  action      AuditAction
  entity_type String
  entity_id   String
  payload     Json
  created_at  DateTime    @default(now())

  @@index([tenant_id, created_at])
  @@map("audit_events")
}

model GuardrailRule {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  rule_type  String
  config     Json
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id])
  @@map("guardrail_rules")
}

model BillingUsage {
  id               String   @id @default(uuid()) @db.Uuid
  tenant_id        String
  tenant           Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  period_start     DateTime
  period_end       DateTime
  total_tool_calls Int
  total_cost_usd   Decimal  @db.Decimal(14, 6)
  created_at       DateTime @default(now())

  @@index([tenant_id, period_start])
  @@map("billing_usage")
}

model EmbeddingStore {
  id         String                      @id @default(uuid()) @db.Uuid
  // null = global shared data (e.g. HTS codes); non-null = tenant-scoped RAG content
  tenant_id  String?
  tenant     Tenant?                     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  // Logical category: 'hts-codes', 'bol-templates', etc.
  namespace  String                      @default("general")
  // FK to source record in its own table (e.g. HtsCode.id); null for free-form content
  entity_id  String?
  // Free-form content for tenant RAG use (optional for structured entity embeddings)
  content    String?
  embedding  Unsupported("vector(1536)")
  metadata   Json?
  created_at DateTime                    @default(now())

  @@index([tenant_id])
  @@index([namespace])
  @@map("embedding_store")
}

model HtsCode {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  description String
  chapter     String
  section     String?
  duty_rate   String?
  unit        String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([chapter])
  @@map("hts_codes")
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  clerk_id   String   @unique
  tenant_id  String
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@index([tenant_id])
  @@map("users")
}

model ApprovalRequest {
  id            String          @id @default(uuid()) @db.Uuid
  tenant_id     String
  tenant        Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  trigger       ApprovalTrigger
  status        ApprovalStatus  @default(PENDING)
  /// Flexible JSON payload: shipment cost, HTS confidence, etc.
  context       Json
  /// ISO-8601 timestamp after which this request auto-expires (optional)
  expires_at    DateTime?
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt

  decisions ApprovalDecision[]

  @@index([tenant_id, status])
  @@index([tenant_id, created_at])
  @@map("approval_requests")
}

model ApprovalDecision {
  id          String          @id @default(uuid()) @db.Uuid
  request_id  String          @db.Uuid
  request     ApprovalRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  /// Clerk user-id of the approver
  decided_by  String
  decision    ApprovalStatus
  note        String?
  decided_at  DateTime        @default(now())

  @@index([request_id])
  @@map("approval_decisions")
}

model ProcessedWebhook {
  stripe_event_id String   @id
  event_type      String
  processed_at    DateTime @default(now())

  @@map("processed_webhooks")
}

// ---------------------------------------------------------------------------
// Outbound webhooks (Week 3) — tenant-registered endpoints + delivery log.
// Field names are snake_case to match the rest of this schema; the original
// Week 3 spec used camelCase but repo convention wins for consistency.
// ---------------------------------------------------------------------------

model Webhook {
  id           String            @id @default(cuid())
  tenant_id    String
  tenant       Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  url          String
  /// HMAC signing secret — generated at creation, returned once, stored as-is (not a password)
  secret       String
  events       String[]          // subscribed event types
  description  String?
  is_active    Boolean           @default(true)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
  deliveries   WebhookDelivery[]

  @@index([tenant_id])
  @@map("webhooks")
}

// ---------------------------------------------------------------------------
// Per-tenant guardrail configuration (Week 4). One row per tenant; absence
// means platform defaults (GUARDRAIL_DEFAULTS) apply. snake_case per repo
// convention. `cost_threshold` / `auto_approve_below` are USD amounts.
// ---------------------------------------------------------------------------

model GuardrailConfig {
  id                    String   @id @default(cuid())
  tenant_id             String   @unique
  tenant                Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  cost_threshold        Float    @default(10000)
  approved_carriers     String[] @default([])
  require_broker_verify Boolean  @default(true)
  auto_approve_below    Float    @default(0)
  updated_at            DateTime @updatedAt

  @@map("guardrail_configs")
}

model WebhookDelivery {
  id            String    @id @default(cuid())
  webhook_id    String
  webhook       Webhook   @relation(fields: [webhook_id], references: [id], onDelete: Cascade)
  event         String
  payload       Json
  status_code   Int?
  response_body String?
  success       Boolean
  attempt_count Int       @default(1)
  next_retry_at DateTime?
  delivered_at  DateTime?
  created_at    DateTime  @default(now())

  @@index([webhook_id])
  @@index([created_at])
  @@map("webhook_deliveries")
}
