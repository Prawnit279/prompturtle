{
  "name": "@prompturtle/backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:no-raw-anthropic": "! grep -rn 'anthropic.messages.create\\|anthropic.messages.stream' src/ --include='*.ts' | grep -v '__tests__' | grep -v 'cost-tracker.ts'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@clerk/clerk-sdk-node": "^4.13.0",
    "@prisma/client": "^5.15.0",
    "@sentry/node": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "resend": "^3.3.0",
    "tiktoken": "^1.0.15",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "prisma": "^5.15.0",
    "supertest": "^7.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
