# E2E Test Environment
# ─────────────────────────────────────────────────────────────────
# These vars are used by Playwright E2E tests only.
# See apps/backend/.env.example for backend env vars.
# See apps/frontend/.env.example for frontend (Vite) env vars.

# Clerk test user — must be pre-created in Clerk dashboard (test environment)
CLERK_TEST_USER_EMAIL=test@example.com
CLERK_TEST_USER_PASSWORD=replace-with-test-password

# Progue API key for E2E direct API tests — must be a key for the test tenant
E2E_TEST_API_KEY=ptk_replace_me

# Endpoints (defaults match local dev — override for staging/preview)
E2E_BASE_URL=http://localhost:5173
E2E_API_URL=http://localhost:3000
